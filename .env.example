# Copy this file to .env and fill in your values
# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=your-model-name
# GitHub personal access token (needs repo, read:org, workflow scopes)
GITHUB_TOKEN=ghp_your_token_here
# Default GitHub org/user to operate against
GITHUB_DEFAULT_OWNER=your-org-or-username
# Trevorism platform
PLATFORM_BASE_URL=https://trevorism.com
TREVORISM_TENANT_GUID=your-tenant-guid
TREVORISM_USERNAME=your-service-account-username
TREVORISM_PASSWORD=your-service-account-password
# Machine-specific paths (no defaults – must be set per machine)
PS_MODULE_PATH=C:\Users\YourName\Documents\PowerShell\Modules
DEV_DIR=C:\dev
# Agent runtime
MEMORY_DB=memory.db
WORKSPACE_DIR=./repos
