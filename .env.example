# Copy this file to .env and fill in your values
# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=your-model-name
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.95
# Context window: override the number of tokens Ollama allocates per request.
# qwen3.6:27b max on 24 GB VRAM = 65536 (training max = 131072).
# Set to 0 to use Ollama's model default (often only 2048 — too small for agent tasks).
OLLAMA_NUM_CTX=65536
# Cap how many prior conversation turns are replayed into each LLM call (0 = unlimited).
# Reduces context when threads grow long; default is 20.
AGENT_MAX_HISTORY_TURNS=20
# GitHub personal access token (needs repo, read:org, workflow scopes)
GITHUB_TOKEN=your_github_token
# Default GitHub org/user to operate against
GITHUB_DEFAULT_OWNER=your-org-or-username
# Platform
PLATFORM_BASE_URL=https://your-platform.example.com
TREVORISM_TENANT_GUID=your-tenant-guid
TREVORISM_USERNAME=your-service-account-username
TREVORISM_PASSWORD=your-service-account-password
# Machine-specific paths (set per machine)
PS_MODULE_PATH=C:\path\to\PowerShell\Modules
DEV_DIR=C:\path\to\dev-root
# Agent runtime
MEMORY_DB=memory.db
WORKSPACE_DIR=./repos
